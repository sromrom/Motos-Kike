# ===== Motos Kike - Variables de entorno =====
# Copia este fichero a .env y rellena tus valores reales.

# Clave de sesión Flask (genera una aleatoria larga)
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria

# Clave de cifrado AES-256 para datos de clientes (32 bytes en base64 url-safe).
# Genera una con:  python -c "import os,base64;print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
AES_KEY=

# Credenciales del único administrador
ADMIN_USERNAME=admin
# Hash de la contraseña. Genéralo con:
#   python -c "from werkzeug.security import generate_password_hash as g;print(g('TU_CONTRASEÑA'))"
ADMIN_PASSWORD_HASH=

# ===== Email (SMTP) - FUNCIONAL si lo rellenas =====
# Hosting propio (cPanel/Plesk). Pide a tu proveedor los datos SMTP de salida.
# Lo habitual:
#   SMTP_HOST = mail.motoskike.es   (o el host que te indique tu hosting)
#   Puerto 465 con SSL  (recomendado)  -> SMTP_PORT=465 y SMTP_USE_SSL=true
#   Puerto 587 con STARTTLS            -> SMTP_PORT=587 y SMTP_USE_TLS=true
#   SMTP_USER = info@motoskike.es  (el email completo)
#   SMTP_PASSWORD = la contraseña de ESA cuenta de correo
SMTP_HOST=mail.motoskike.es
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USE_TLS=false
SMTP_USER=info@motoskike.es
SMTP_PASSWORD=
SMTP_FROM=Motos Kike <info@motoskike.es>

# ===== Telegram (opcional) - necesita un bot propio =====
# Crea un bot con @BotFather y pega el token. El cliente debe escribir al bot
# para que tengas su chat_id (limitación de Telegram).
TELEGRAM_BOT_TOKEN=

# ===== WhatsApp (opcional) - REQUIERE cuenta de pago =====
# Opción A: Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Opción B: WhatsApp Cloud API (Meta)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
